# Public URL where Shopify can reach this app.
SHOPIFY_APP_URL=""

# Development store domain used when starting local OAuth.
SHOPIFY_SHOP_DOMAIN=""

# Shopify custom app API key from the Partner Dashboard.
SHOPIFY_API_KEY=""

# Shopify custom app API secret used for OAuth and API signing.
SHOPIFY_API_SECRET=""

# Shared secret used to verify Shopify webhook HMAC signatures.
SHOPIFY_WEBHOOK_SECRET=""

# Supabase project URL for the analytics PostgreSQL database.
SUPABASE_URL=""

# Supabase service role key used only by server-side code.
SUPABASE_SERVICE_ROLE_KEY=""

# Secret used by Remix and Shopify session cookies.
SESSION_SECRET=""
